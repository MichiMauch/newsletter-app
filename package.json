{
  "name": "newsletter-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/migrate-prod.mjs && next start",
    "lint": "eslint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx scripts/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed-site": "npx tsx scripts/seed-site.ts",
    "db:migrate-subscribers": "npx tsx scripts/migrate-subscribers.ts",
    "db:migrate-sends": "npx tsx scripts/migrate-sends.ts",
    "db:sync-content": "npx tsx scripts/sync-content.ts",
    "email": "email dev --port 3001 --dir emails",
    "email:export": "email export --dir emails --out .preview-emails",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "db:migrate-test": "npx tsx scripts/e2e-setup.ts",
    "check": "npx tsc --noEmit && vitest run",
    "check:full": "npx tsc --noEmit && vitest run && playwright test",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.85.0",
    "@libsql/client": "^0.17.2",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/nextjs": "^10.50.0",
    "@tiptap/extension-link": "^3.22.1",
    "@tiptap/pm": "^3.22.1",
    "@tiptap/react": "^3.22.1",
    "@tiptap/starter-kit": "^3.22.1",
    "@types/sanitize-html": "^2.16.1",
    "@xyflow/react": "^12.10.2",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.4",
    "sanitize-html": "^2.17.2",
    "sharp": "^0.34.5",
    "svix": "^1.89.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@react-email/preview-server": "^5.2.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "react-email": "^5.2.11",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
