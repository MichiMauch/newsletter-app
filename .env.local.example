# Newsletter-App DB (new, dedicated)
TURSO_DB_URL=libsql://newsletter-xxx.turso.io
TURSO_DB_TOKEN=

# Email sending
RESEND_API_KEY=re_...
RESEND_WEBHOOK_SECRET=whsec_...

# Admin
ADMIN_PASSWORD=

# App URL (where this newsletter app is hosted)
SITE_URL=https://newsletter.kokomo.house

# CORS (comma-separated origins allowed to call /api/v1/*)
ALLOWED_ORIGINS=https://www.kokomo.house

# Cron job auth
CRON_SECRET=

# Confirm-Token HMAC secret — signs the 24h-expiring confirmation links so an
# archived/forwarded confirmation mail cannot be used to silently unsubscribe
# the recipient later. Must be at least 32 characters. Generate via:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CONFIRM_TOKEN_SECRET=

# Cloudflare Turnstile (optional)
TURNSTILE_SECRET_KEY=

# --- For data migration scripts only ---
# kokomo2026 Turso DB (source for migration)
SOURCE_TURSO_DB_URL=libsql://kokomo2026-xxx.turso.io
SOURCE_TURSO_DB_TOKEN=

# Path to kokomo2026 content directory (for content sync)
KOKOMO_CONTENT_DIR=/Users/michaelmauch/Documents/Development/kokomo2026/src/content/posts
